# .env.example — copy to .env and fill secrets (DO NOT COMMIT .env)
# Example Atlas connection (URL-encode special characters in the password)
MONGO_URL="mongodb+srv://<username>:<password>@cluster0.jgql1bw.mongodb.net/?retryWrites=true&w=majority"
DB_NAME=wedwish

# Admin credentials (change for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change-me-please

# Frontend build-time backend URL default
REACT_APP_BACKEND_URL=http://localhost:8001

# Comma-separated list of allowed origins for CORS. Include any frontend domains you use.
# Examples: http://localhost:3000,https://wedwish.mzxt.in,https://wedwishapi.mzxt.in
CORS_ORIGINS=http://localhost:3000,https://wedwish.mzxt.in,https://wedwishapi.mzxt.in
